from PIL import Image

def encrypt_image(input_path, output_path, key):
    img = Image.open(input_path)
    pixels = img.load()

    width, height = img.size

    for x in range(width):
        for y in range(height):

            r, g, b = pixels[x, y]

            # Encrypt pixel values
            r = (r + key) % 256
            g = (g + key) % 256
            b = (b + key) % 256

            pixels[x, y] = (r, g, b)

    img.save(output_path)
    print("Encryption complete. Saved as:", output_path)


def decrypt_image(input_path, output_path, key):
    img = Image.open(input_path)
    pixels = img.load()

    width, height = img.size

    for x in range(width):
        for y in range(height):

            r, g, b = pixels[x, y]

            # Decrypt pixel values
            r = (r - key) % 256
            g = (g - key) % 256
            b = (b - key) % 256

            pixels[x, y] = (r, g, b)

    img.save(output_path)
    print("Decryption complete. Saved as:", output_path)


key = int(input("Enter encryption key (number): "))

encrypt_image("Cyber_Security.jpg", "encrypted_image.png", key)

decrypt_image("encrypted_image.png", "decrypted_image.png", key)
